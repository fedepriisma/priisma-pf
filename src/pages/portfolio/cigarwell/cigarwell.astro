---
import ProjectDetails from "../../../components/ProjectDetails.astro";
---

<!-- Cigarwell — listed first -->
<article
  id="cigarwell"
  class="section-space text-cw-light bg-linear-(--cw-gradient)"
>
<p class="text-sm font-medium tracking-wide uppercase opacity-60 mb-2">Product concept, design, and launch.</p>
  <h3 class="section-header">
    <span class="bg-black text-yellow">Cigarwell</span>
  </h3>
  <ProjectDetails
    role="Product strategy · UX · Interface design · Design system · Branding"
    projectDate="2023–2024"
    projName="Cigarwell.com"
    projUrl="https://cigarwell.com"
  />
  <figure>
    <div
      class="w-full rounded-md border border-current/20 bg-midnight/5"
      style="aspect-ratio: 16/10;"
      role="img"
      aria-label="Cigarwell product interface — designed by Priisma"
    >
    </div>
  </figure>
  <p class="mt-8 max-w-prose text-base">
    A platform for cigar enthusiasts to track their collection, explore new
    cigars, and build a more intentional experience around enjoying them.
  </p>

  <a href="/work/cigarwell" class="inline-block mt-4 text-sm font-medium underline underline-offset-4 opacity-60 hover:opacity-100 motion-safe:transition-opacity">
    View full case study →
  </a>
</article>
