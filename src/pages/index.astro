---
// Component Imports
import MainHead from "../components/MainHead.astro";
import ContactInfo from "../components/ContactInfo.astro";
import Footer from "../components/Footer.astro";
import Quotingbill from "./portfolio/quotingbill/quotingbill.astro";
import Godark from "./portfolio/godark/godark.astro";
import Flyairways from "./portfolio/flyairways/flyairways.astro";
import MchAnywhere from "./portfolio/mch/mch.astro";

// Lightbox https://github.com/hellotham/hello-astro/blob/main/src/components/lightbox.astro
// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/
---
<script>
	import PhotoSwipeLightbox from 'photoswipe/lightbox';
	import 'photoswipe/style.css';
	  const lightbox = new PhotoSwipeLightbox({
	  gallery: '#breadboarding-gallery, #fatmarkers-gallery, #sectiondetails-gallery, #flyairways-gallery, #mch-gallery',
	  children: 'a',
	  pswpModule: () => import('photoswipe')
	});
	lightbox.init();
</script>
<html lang="en">
	<head>
		<MainHead
			title="Fede Bozo — Product Designer"
			description="Fede Bozo is a Product Designer in Miami with 10+ years building digital products for airlines, hospitals, startups, and more."
			canonical="https://www.priisma.com/"
			image="/assets/mesh-gradient.jpg"
		/>
	</head>
	
	<body class="selection:bg-fuchsia-300 selection:text-fuchsia-900 bg-purplehaze text-whiterabbit">
	<header class="sticky z-50 px-4 py-4 mx-2 border border-solid rounded-full sm:px-8 sm:mx-8 top-2 bg-purplehaze/70 text-whiterabbit backdrop-blur-md border-whiterabbit/30">
		<ContactInfo />
	</header>
		<div class="relative max-w-4xl mx-auto my-16 ml-4 text-left md:my-24 lg:my-32">
			<p class="mb-4 text-md">Strategic Product Design · Miami</p>
			<h1 class="text-5xl font-medium font-display font-stretch-expanded">Design <br />that moves <br />the needle.</h1>
			<h2 class="mt-6 text-base max-w-prose">Fede Bozo — Product Designer and Developer. Working from concept to launch turning complex problems into products people actually use, leading zero-to-one initiatives and full redesigns as a strategic partner.</h2>
		</div>
		<main class="main-thingi">
			<div class="grid">
				<Quotingbill />
				<MchAnywhere />
				<Flyairways />
				<!-- <Godark /> -->
			</div>
		</main>
		<Footer />
	</body>
</html>
