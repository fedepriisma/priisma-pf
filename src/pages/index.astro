---
// Priisma — one-page beacon. Quiet system-type edition: paper, ink, one hot accent, no rules.
import { Image } from "astro:assets";
import sbShot from "../img/showbliz-shot.jpg";
import cwHome from "../img/cigarwell-home.png";
import qbInvoice from "./portfolio/quotingbill/qb-invoice.png";
import gdWeb from "./portfolio/godark/godark-web-01.jpg";
import flyDevices from "./portfolio/flyairways/fly-airways-devices.png";
import mchTablet from "./portfolio/mch/mch-tablet-view.png";

const ogImage = new URL(sbShot.src, Astro.site).href;

const year = new Date().getFullYear();

const archive = [
	{ n: "001", name: "Cigarwell", meta: "Product · Brand · Copy", year: "2023–24", img: cwHome, alt: "Cigarwell mobile home screen" },
	{ n: "002", name: "QuotingBill", meta: "Product · SaaS", year: "2019", img: qbInvoice, alt: "QuotingBill invoice screen" },
	{ n: "003", name: "GoDark Chocolates", meta: "Brand · Web", year: "2017", img: gdWeb, alt: "GoDark Chocolates website" },
	{ n: "004", name: "airTRFX", meta: "Product · Web", year: "2016", img: flyDevices, alt: "airTRFX fare pages across devices" },
	{ n: "005", name: "MCH Anywhere", meta: "UX · iOS · Android", year: "2015", img: mchTablet, alt: "MCH Anywhere tablet view" },
];

const cycle = [
	{ n: "01", t: "Product thinking", d: "Discover what matters." },
	{ n: "02", t: "Brand systems", d: "Identity with clarity." },
	{ n: "03", t: "Code + AI", d: "Build smarter. Ship faster." },
	{ n: "04", t: "Copy + launch", d: "Tell it right. Release it right." },
];

// Tonight's real listings, fetched at build time from the Showbliz feed.
// Falls back to a snapshot if the feed is unreachable so builds never break.
const snapshot: { show: string; venue: string; img?: string }[] = [
	{ show: "The Shark Is Broken", venue: "Actors Playhouse, Coral Gables" },
	{ show: "Todo Lo Que No Dije", venue: "Colony Theatre, Miami Beach" },
	{ show: "In The Heights", venue: "Lake Worth Playhouse" },
	{ show: "Fresa y Chocolate", venue: "Teatro Trail, Little Havana" },
	{ show: "Bluey's Big Play", venue: "Broward Center, Fort Lauderdale" },
	{ show: "El Intercambio", venue: "Teatro Trail, Little Havana" },
	{ show: "Probemos y ya!", venue: "Teatro Miami, Medley" },
	{ show: "The Wizard of Oz", venue: "Actors Playhouse, Coral Gables" },
	{ show: "Daymé Arocena", venue: "Teatro Trail, Little Havana" },
	{ show: "Matt & Ben", venue: "Empire Stage, Fort Lauderdale" },
];

const codePoint = (n: number) => (n > 0 && n <= 0x10ffff ? String.fromCodePoint(n) : "�");
const decode = (s: string) =>
	s
		.replace(/<!\[CDATA\[([\s\S]*?)\]\]>/g, "$1")
		.replace(/&#x([0-9a-fA-F]+);/g, (_, h) => codePoint(parseInt(h, 16)))
		.replace(/&#(\d+);/g, (_, n) => codePoint(Number(n)))
		.replace(/&lt;/g, "<")
		.replace(/&gt;/g, ">")
		.replace(/&quot;/g, '"')
		.replace(/&apos;/g, "'")
		.replace(/&amp;/g, "&")
		.trim();

let onStage = snapshot;
let liveFeed = false;
try {
	const res = await fetch("https://showbliz.com/feed/today.xml", {
		signal: AbortSignal.timeout(10_000),
	});
	const size = Number(res.headers.get("content-length") ?? 0);
	if (size > 2_000_000) throw new Error(`feed too large (${size} bytes)`);
	if (res.ok) {
		const xml = await res.text();
		const items = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/g)]
			.map((m) => {
				const tag = (t: string) =>
					m[1].match(new RegExp(`<${t}(?:\\s[^>]*)?>([\\s\\S]*?)</${t}>`))?.[1] ?? "";
				const venue = decode(tag("description")).replace(/^At\s+/, "").split("·")[0].trim();
				// trust boundary: only render poster URLs from the Showbliz CDN
				const rawImg = decode(m[1].match(/<enclosure[^>]*\burl="([^"]+)"/)?.[1] ?? "");
				const img = rawImg.startsWith("https://cdn.showbliz.com/") ? rawImg : undefined;
				return { show: decode(tag("title")), venue, img };
			})
			.filter((s) => s.show);
		console.log(`[showbliz feed] parsed ${items.length} items`);
		if (items.length) {
			onStage = items.slice(0, 14);
			liveFeed = true;
		}
	} else {
		console.warn(`[showbliz feed] HTTP ${res.status} — using snapshot fallback`);
	}
} catch (e) {
	console.warn(`[showbliz feed] fetch failed (${e}) — using snapshot fallback`);
}
// keep the ticker dense when tonight is a quiet night; padded repeats are
// marked so screen readers only hear each show once
const realCount = onStage.length;
while (onStage.length && onStage.length < 8) onStage = [...onStage, ...onStage];
const ticker = onStage.map((s, i) => ({ ...s, pad: i >= realCount }));
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Fede Bozo · Priisma: I design by building</title>
		<meta
			name="description"
			content="Head of design who ships. Now building Showbliz, Miami's performing-arts ecosystem: designed and built by one person in three months. Looking for partners in crime."
		/>
		<link rel="canonical" href="https://www.priisma.com/" />
		<link rel="icon" href="/favicon.ico" sizes="32x32" />
		<meta property="og:title" content="Fede Bozo · Priisma" />
		<meta property="og:description" content="I design by building." />
		<meta property="og:url" content="https://www.priisma.com/" />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={ogImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="theme-color" content="#f2efe9" />
	</head>

	<body>
		<header class="top">
			<span class="brand">Fede&nbsp;Bozo <em>/ Priisma</em></span>
			<a class="top-mail" href="mailto:fede@priisma.com">fede@priisma.com</a>
		</header>

		<main>
			<!-- HERO -->
			<section class="hero" aria-label="Intro">
				<div class="hero-side" aria-hidden="true">
					<svg class="stamp" viewBox="0 0 100 100">
						<defs>
							<path id="ring" d="M50,50 m-37,0 a37,37 0 1,1 74,0 a37,37 0 1,1 -74,0"></path>
						</defs>
						<g class="stamp-spin">
							<text class="stamp-ring">
								<textPath href="#ring" startOffset="0"
									>PRODUCT DESIGNER · MIAMI FL · PRODUCT DESIGNER ·</textPath
								>
							</text>
						</g>
						<text class="stamp-year" x="50" y="46" text-anchor="middle">20</text>
						<text class="stamp-year" x="50" y="64" text-anchor="middle">26</text>
					</svg>
					<span class="coords">Based in Miami, FL · 25.7617° N, 80.1918° W</span>
					<span class="palm">✳</span>
				</div>

				<div class="hero-main">
					<p class="tag reveal">Product design · Miami</p>
					<h1>
						<span class="line reveal d1">I design</span>
						<span class="line reveal d2">by building.</span>
					</h1>
					<p class="hero-sub reveal d3">
						The whole cycle: product thinking, brand, design system, code, copy, launch.
					</p>
					<p class="hero-voice reveal d3">
						AI is my <strong>crew</strong>. Taste is the bottleneck, and I own it.
					</p>
					<div class="ctas reveal d3">
						<a class="btn solid" href="#now">See Showbliz</a>
						<a class="btn" href="mailto:fede@priisma.com">Let&rsquo;s build</a>
					</div>

					<ol class="cycle reveal d3" role="list" aria-label="The whole cycle">
						{
							cycle.map((c) => (
								<li>
									<span class="cycle-n">{c.n}</span>
									<span class="cycle-t">{c.t}</span>
									<span class="cycle-d">{c.d}</span>
								</li>
							))
						}
					</ol>
				</div>
			</section>

			<!-- NOW / SHOWBLIZ -->
			<section class="now" id="now" aria-label="Now: Showbliz">
				<div class="now-inner">
					<p class="tag now-tag">Now · Live</p>
					<h2 class="now-title">Showbliz</h2>
					<p class="now-statement">
						Every city has an art soul.<br />Miami&rsquo;s now has a home.
					</p>
					<a class="fig-link" href="https://showbliz.com" target="_blank" rel="noopener">
						<figure class="fig">
							<Image src={sbShot} alt="Showbliz homepage: tonight's shows across Miami and South Florida" widths={[640, 1024, 1400]} sizes="(min-width: 64rem) 62rem, 94vw" format="webp" loading="lazy" decoding="async" />
							<figcaption>Fig. 01 · Showbliz.com <span>live product ↗</span></figcaption>
						</figure>
					</a>
				</div>

				<!-- the product, in its own words: real listings -->
				<div
					class="marquee"
					id="stage-marquee"
					role="marquee"
					aria-label={
						liveFeed
							? "On Miami stages tonight, via Showbliz"
							: "Recently on Miami stages, via Showbliz"
					}
				>
					<div class="marquee-track">
						{
							[0, 1].map((dup) => (
								<ul role={dup === 0 ? "list" : undefined} aria-hidden={dup === 1 || undefined}>
									{ticker.map((s) => (
										<li aria-hidden={s.pad || undefined}>
											{s.img && (
												<img src={s.img} alt="" width="88" height="46" loading="lazy" decoding="async" />
											)}
											<strong>{s.show}</strong>
											<span>{s.venue}</span>
										</li>
									))}
								</ul>
							))
						}
					</div>
				</div>
				<div class="marquee-bar">
					<p class="marquee-label">
						{
							liveFeed
								? "On Miami stages tonight, straight from the Showbliz feed"
								: "Recently on Miami stages, via Showbliz"
						}
					</p>
					<button class="marquee-toggle" type="button" aria-controls="stage-marquee">
						Pause
					</button>
				</div>

				<div class="now-inner">
					<ul class="stats" role="list">
						<li><strong>200+</strong><span>shows on stage</span></li>
						<li><strong>30+</strong><span>venues, one map</span></li>
						<li><strong>2</strong><span>languages, EN&thinsp;/&thinsp;ES</span></li>
						<li><strong>3 mo</strong><span>concept to launch</span></li>
					</ul>
					<p class="now-note">
						Not a case study. A working ecosystem: designed, written, coded, and shipped by one
						person, for a real city.
					</p>
					<a class="btn solid inverse" href="https://showbliz.com" target="_blank" rel="noopener">
						showbliz.com
					</a>
				</div>
			</section>

			<!-- BEFORE / ARCHIVE -->
			<section class="ledger" aria-label="Previous work">
				<h2 class="tag">Before</h2>
				<ol role="list">
					{
						archive.map((p) => (
							<li class="row">
								<span class="row-n">{p.n}</span>
								<Image
									class="row-thumb"
									src={p.img}
									alt={p.alt}
									widths={[176, 352]}
									sizes="88px"
									format="webp"
									loading="lazy"
									decoding="async"
								/>
								<span class="row-name">{p.name}</span>
								<span class="row-meta">{p.meta}</span>
								<span class="row-year">{p.year}</span>
							</li>
						))
					}
				</ol>
				<p class="ledger-note">Ten years of shipped product. Ask me about any of it.</p>
			</section>

			<!-- CONTACT -->
			<section class="contact" aria-label="Contact">
				<h2 class="tag">Building something real?</h2>
				<a class="mail" href="mailto:fede@priisma.com">fede@priisma.com</a>
				<p class="filter">
					Not looking for clients to convince.<br />Looking for
					<strong>partners in crime</strong>.
				</p>
			</section>
		</main>

		<footer class="foot">
			<span class="foot-item"><strong>Current focus</strong> Showbliz.com</span>
			<span class="foot-item">AI-native design cycles</span>
			<span class="foot-item grow">© {year} Priisma · Miami</span>
			<a class="foot-item" href="https://www.linkedin.com/in/fedebozo" target="_blank" rel="noopener"
				>LinkedIn ↗</a
			>
		</footer>
		<script>
			// WCAG 2.2.2: keyboard/touch pause for the ticker
			const marquee = document.getElementById("stage-marquee");
			const toggle = document.querySelector<HTMLButtonElement>(".marquee-toggle");
			toggle?.addEventListener("click", () => {
				const paused = marquee?.classList.toggle("paused");
				toggle.textContent = paused ? "Play" : "Pause";
			});
			// idle the ticker while offscreen (battery)
			const io = new IntersectionObserver(
				(entries) => {
					for (const e of entries) e.target.classList.toggle("idle", !e.isIntersecting);
				},
				{ rootMargin: "10%" }
			);
			if (marquee) io.observe(marquee);
		</script>
	</body>
</html>

<style is:global>
	/* ————— tokens ————— */
	:root {
		--paper: oklch(95% 0.008 85);
		--ink: oklch(17% 0.012 60);
		--accent: oklch(63% 0.19 33); /* hot coral */
		--accent-text: oklch(50% 0.185 33); /* coral dark enough for small text on paper (AA) */
		--sans:
			system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
		--pad: clamp(1.1rem, 3.5vw, 2.75rem);
		--measure: 68rem;

		/* the whole page uses exactly four sizes */
		--fs-caption: 0.75rem;
		--fs-eyebrow: 0.8125rem;
		--fs-body: 1rem;
		--fs-title: clamp(1.9rem, 1.45rem + 1.9vw, 2.75rem);
	}

	/* ————— base ————— */
	*,
	*::before,
	*::after {
		box-sizing: border-box;
		margin: 0;
	}
	html {
		scroll-behavior: smooth;
		background: var(--paper);
	}
	body {
		background: var(--paper);
		color: var(--ink);
		font-family: var(--sans);
		font-size: var(--fs-body);
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
	}
	::selection {
		background: var(--accent);
		color: var(--paper);
	}
	a {
		color: currentColor;
	}
	:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}
	strong {
		font-weight: 650;
	}

	.tag {
		font-size: var(--fs-eyebrow);
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}

	/* ————— header ————— */
	.top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.1rem var(--pad);
	}
	.brand {
		font-size: var(--fs-eyebrow);
		font-weight: 700;
	}
	.brand em {
		font-style: normal;
		font-weight: 400;
		opacity: 0.65;
	}
	.top-mail {
		font-size: var(--fs-caption);
		text-decoration: none;
		padding-block: 0.5rem;
	}
	.top-mail:hover,
	.top-mail:focus-visible {
		text-decoration: underline;
		text-underline-offset: 0.25em;
	}

	/* ————— hero: rail on top (mobile), vertical rail beside (desktop) ————— */
	.hero {
		display: grid;
	}
	.hero-side {
		display: flex;
		align-items: center;
		gap: 1.2rem;
		padding: 1rem var(--pad);
		color: var(--accent);
	}
	.stamp {
		inline-size: 5.4rem;
		flex: none;
		fill: var(--accent);
		overflow: visible;
	}
	.stamp-spin {
		animation: spin 36s linear infinite;
		transform-origin: 50px 50px;
	}
	.stamp-ring {
		font-size: 10.5px;
		letter-spacing: 2px;
	}
	.stamp-year {
		font-weight: 800;
		font-size: 17px;
	}
	@keyframes spin {
		to {
			rotate: 1turn;
		}
	}
	.coords {
		font-size: var(--fs-caption);
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ink);
		opacity: 0.7;
	}
	.palm {
		margin-inline-start: auto;
		font-size: var(--fs-title);
		line-height: 1;
	}
	.hero-main {
		padding: clamp(3rem, 9dvh, 6rem) var(--pad) clamp(2.5rem, 7dvh, 5rem);
		text-align: center;
	}
	.hero h1 {
		font-size: var(--fs-title);
		font-weight: 800;
		line-height: 1.05;
		letter-spacing: -0.01em;
		margin-block-start: 1rem;
	}
	.hero h1 .line {
		display: block;
	}
	.hero-sub {
		margin-block-start: 1.4rem;
		max-inline-size: 46ch;
		margin-inline: auto;
	}
	.hero-voice {
		margin-block-start: 0.6rem;
		max-inline-size: 46ch;
		margin-inline: auto;
		opacity: 0.85;
	}
	.ctas {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.8rem;
		margin-block-start: 2.2rem;
	}
	.btn {
		font-size: var(--fs-eyebrow);
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		text-decoration: none;
		padding: 0.8rem 1.5rem;
		display: inline-flex;
		align-items: center;
		gap: 0.6em;
		color: var(--ink);
		transition: opacity 0.15s ease;
	}
	.btn.solid {
		background: var(--ink);
		color: var(--paper);
	}
	.btn:not(.solid) {
		text-decoration: underline;
		text-underline-offset: 0.3em;
	}
	.btn:hover {
		opacity: 0.85;
	}
	.btn.solid.inverse {
		background: var(--paper);
		color: var(--ink);
	}

	/* the whole cycle, quiet strip */
	.cycle {
		list-style: none;
		padding: 0;
		margin-block-start: clamp(3rem, 8dvh, 5rem);
		display: grid;
		gap: 1.1rem;
		justify-items: center;
	}
	.cycle li {
		display: grid;
		justify-items: center;
		gap: 0.15rem;
	}
	/* connect the steps: it reads as a sequence, not four floating notes */
	.cycle li + li::before {
		content: "↓" / "";
		color: var(--accent-text);
		font-size: var(--fs-caption);
		line-height: 1;
		padding-block-end: 0.6rem;
	}
	.cycle-n {
		color: var(--accent-text);
		font-size: var(--fs-caption);
		font-weight: 600;
	}
	.cycle-t {
		font-size: var(--fs-body);
		font-weight: 650;
	}
	.cycle-d {
		font-size: var(--fs-caption);
		opacity: 0.7;
	}

	/* ————— now / showbliz: ink band ————— */
	.now {
		background: var(--ink);
		color: var(--paper);
	}
	.now-inner {
		padding: clamp(2.6rem, 7dvh, 5rem) var(--pad);
		max-inline-size: var(--measure);
		margin-inline: auto;
	}
	.now-tag {
		color: var(--accent);
	}
	.now-title {
		font-size: var(--fs-title);
		font-weight: 800;
		line-height: 1.05;
		margin-block-start: 0.6rem;
	}
	.now-statement {
		margin-block-start: 0.8rem;
		max-inline-size: 46ch;
	}

	/* marquee */
	.marquee {
		overflow: clip;
		padding-block: 0.6rem;
	}
	.marquee-track {
		display: flex;
		width: max-content;
		animation: slide 45s linear infinite;
	}
	.marquee:hover .marquee-track {
		animation-play-state: paused;
	}
	.marquee-track ul {
		display: flex;
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.marquee-track li {
		display: flex;
		align-items: center;
		gap: 0.8em;
		white-space: nowrap;
		margin-inline-end: 3rem;
	}
	.marquee-track img {
		block-size: 2.6rem;
		inline-size: auto;
		aspect-ratio: 88 / 46;
		object-fit: cover;
	}
	.marquee-track strong {
		font-size: var(--fs-eyebrow);
	}
	.marquee-track span {
		font-size: var(--fs-caption);
		opacity: 0.65;
	}
	@keyframes slide {
		to {
			translate: -50% 0;
		}
	}
	.marquee-bar {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.6rem var(--pad) 0;
		max-inline-size: var(--measure);
		margin-inline: auto;
	}
	.marquee-label {
		font-size: var(--fs-caption);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		opacity: 0.6;
	}
	.marquee-toggle {
		font-family: var(--sans);
		font-size: var(--fs-caption);
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--paper);
		background: color-mix(in oklch, var(--paper) 14%, var(--ink));
		border: none;
		padding: 0.6em 1.1em;
		cursor: pointer;
	}
	.marquee-toggle:hover {
		background: var(--paper);
		color: var(--ink);
	}
	.marquee.paused .marquee-track,
	.marquee.idle .marquee-track {
		animation-play-state: paused;
	}
	@media (prefers-reduced-motion: reduce) {
		.marquee {
			overflow-x: auto;
		}
		.marquee-track ul[aria-hidden="true"] {
			display: none;
		}
		.marquee-toggle {
			display: none;
		}
	}

	/* stats */
	.stats {
		list-style: none;
		padding: 0;
