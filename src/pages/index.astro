---
// Component Imports
import MainHead from "../components/MainHead.astro";
import ContactInfo from "../components/ContactInfo.astro";
import Footer from "../components/Footer.astro";
import Quotingbill from "./portfolio/quotingbill/quotingbill.astro";
import Godark from "./portfolio/godark/godark.astro";
import Flyairways from "./portfolio/flyairways/flyairways.astro";
import MchAnywhere from "./portfolio/mch/mch.astro";

// Lightbox https://github.com/hellotham/hello-astro/blob/main/src/components/lightbox.astro
// Full Astro Component Syntax:
// https://docs.astro.build/core-concepts/astro-components/
---
<script>
	import PhotoSwipeLightbox from 'photoswipe/lightbox';
	import 'photoswipe/style.css';
	  const lightbox = new PhotoSwipeLightbox({
	  gallery: '#breadboarding-gallery, #fatmarkers-gallery, #sectiondetails-gallery, #flyairways-gallery, #mch-gallery',
	  children: 'a',
	  pswpModule: () => import('photoswipe')
	});
	lightbox.init();
</script>
<html lang="en">
	<head>
		<MainHead
			title="Fede Bozo — Product Designer"
			description="Fede Bozo is a Product Designer in Miami with 10+ years building digital products for airlines, hospitals, startups, and more."
			canonical="https://www.priisma.com/"
			image="/assets/mesh-gradient.jpg"
		/>
	</head>
	
	<body class="body-base">
	<header class="nav-floater">
		<ContactInfo />
	</header>
		<div class="relative mx-auto my-16 ml-4 md:my-16 lg:my-24 text-center">
			<h1 class="text-5xl font-display">Designing products that are ready to scale.</h1>
			<p class="mt-6 text-md max-w-prose mx-auto">Turning funded startups and SaaS companies from good products into great ones.</p>
			<p class="mt-6 text-md max-w-prose mx-auto">From product strategy and design leadership to hands-on execution — we help teams shape, build, and evolve digital products people genuinely enjoy using.</p>
			<p class="mt-6 text-md max-w-prose mx-auto">Real culture, a strong voice, a cohesive system, and a presence that earns trust before anyone says a word.</p>
	<a href="#open-convo" class="primary-cta">Let's talk</a>
		</div>
		<main class="main-thingi">
			<div class="grid">
				<Quotingbill />
				<MchAnywhere />
				<Flyairways />
				<!-- <Godark /> -->
			</div>
		</main>
		<Footer />
	</body>
</html>
