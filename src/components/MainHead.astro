---
const {
	title = 'Fede Bozo: Designer',
	description = 'Fede Bozo — Designer',
	canonical = undefined,
	image = undefined,
} = Astro.props;
const defaultImage = '/assets/mesh-gradient.jpg';
import HeaderScripts from '../components/HeaderScripts.astro';
import '../styles/tailwind.css'
// JSON-LD defaults
const defaultSite = 'https://www.priisma.com';
let siteOrigin = defaultSite;
try {
	siteOrigin = canonical ? new URL(canonical).origin : defaultSite;
} catch (e) {
	siteOrigin = defaultSite;
}

const org = {
	'@type': 'Organization',
	name: 'Priisma',
	url: siteOrigin,
	logo: `${siteOrigin}/assets/mesh-gradient.jpg`
};

const website = {
	'@type': 'WebSite',
	url: siteOrigin,
	name: title,
	description,
	potentialAction: {
		'@type': 'SearchAction',
		target: `${siteOrigin}/search?q={search_term_string}`,
		'query-input': 'required name=search_term_string'
	}
};

const jsonGraph = [org, website];
if (Astro.props.breadcrumb && Array.isArray(Astro.props.breadcrumb)) {
	const items = Astro.props.breadcrumb.map((b, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		name: b.name,
		item: b.url.startsWith('http') ? b.url : siteOrigin + b.url
	}));
	jsonGraph.push({
		'@type': 'BreadcrumbList',
		itemListElement: items
	});
}
const jsonLd = { '@context': 'https://schema.org', '@graph': jsonGraph };
---
<HeaderScripts />
<meta charset="UTF-8" />
<meta name="description" content={description} />
<meta property="og:description" content={description} />
<meta property="og:title" content={title} />
<meta property="og:type" content="website" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="robots" content="index,follow" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<title>{title}</title>

{canonical && <link rel="canonical" href={canonical} />}
<meta property="og:image" content={image ?? defaultImage} />
<meta name="twitter:image" content={image ?? defaultImage} />

<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Mona+Sans:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>