---
const {
	title = 'Fede Bozo: Designer',
	description = 'Fede Bozo — Designer',
	canonical = undefined,
	image = undefined,
	preloadImage = undefined,
} = Astro.props;
const defaultImage = '/assets/mesh-gradient.jpg';
import HeaderScripts from '../components/HeaderScripts.astro';
import PostHog from '../components/PostHog.astro';
import '../styles/tailwind.css'
// JSON-LD defaults
const defaultSite = 'https://www.priisma.com';
let siteOrigin = defaultSite;
try {
	siteOrigin = canonical ? new URL(canonical).origin : defaultSite;
} catch (e) {
	siteOrigin = defaultSite;
}

const org = {
	'@type': 'ProfessionalService',
	name: 'Priisma',
	url: siteOrigin,
	logo: `${siteOrigin}/assets/mesh-gradient.jpg`,
	description: 'Product design leadership for scaling SaaS companies',
	areaServed: ['US', 'Latin America'],
	founder: {
		'@type': 'Person',
		name: 'Fede Bozo',
		jobTitle: 'Product Designer',
		url: 'https://www.linkedin.com/in/fedebozo/'
	}
};

const website = {
	'@type': 'WebSite',
	url: siteOrigin,
	name: title,
	description,
};

const jsonGraph: Record<string, unknown>[] = [org, website];
if (Astro.props.breadcrumb && Array.isArray(Astro.props.breadcrumb)) {
	const items = Astro.props.breadcrumb.map((b, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		name: b.name,
		item: b.url.startsWith('http') ? b.url : siteOrigin + b.url
	}));
	jsonGraph.push({
		'@type': 'BreadcrumbList',
		itemListElement: items
	});
}
const jsonLd = { '@context': 'https://schema.org', '@graph': jsonGraph };
---
<HeaderScripts />
<meta charset="UTF-8" />
<meta name="description" content={description} />
<meta property="og:description" content={description} />
<meta property="og:title" content={title} />
<meta property="og:type" content="website" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="robots" content="index,follow" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<title>{title}</title>

{canonical && <link rel="canonical" href={canonical} />}
{canonical && <meta property="og:url" content={canonical} />}
<meta property="og:image" content={image ?? defaultImage} />
<meta name="twitter:image" content={image ?? defaultImage} />

<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<!-- Preload local variable font to avoid incorrect relative hrefs in generated HTML -->
<link rel="preload" href="/fonts/Mona-Sans.woff2" as="font" type="font/woff2" crossorigin>
<!-- Local @font-face with font-display to avoid render-blocking and 404 preload issues -->
<style>
@font-face{font-family:'Mona Sans';src: url('/fonts/Mona-Sans.woff2') format('woff2-variations');font-weight:200 900;font-stretch:75% 125%;font-display:swap}
</style>

<!-- Instrument Serif (display font) from Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">

<PostHog />

<!-- Optional LCP/image preload: pass `preloadImage` prop from pages that know their hero LCP -->
{preloadImage && <link rel="preload" href={preloadImage} as="image" />}

<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>